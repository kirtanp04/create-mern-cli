{
  "name": "mern-builder",
  "version": "1.1.0",
  "description": "Scaffold a full-stack MERN app with Vite + TypeScript — like create-next-app but for MERN",
  "main": "dist/index.js",
  "bin": {
    "mern-builder": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mern",
    "mern-builder",
    "vite",
    "typescript",
    "cli",
    "scaffold",
    "create-app",
    "react",
    "express",
    "mongodb",
    "postgresql",
    "full-stack"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kirtanp04/create-mern-cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "gradient-string": "^2.0.2",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.5",
    "@types/node": "^20.11.0",
    "semantic-release": "^24.2.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
